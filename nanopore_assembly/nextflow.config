// ============================================================================
// Dana Nanopore Assembly Pipeline - Nextflow Configuration
// ============================================================================

// Default parameters (override via CLI: --param_name value)
params {
    // Help
    help            = false

    // Required
    input           = null      // Directory containing *.fastq.gz reads

    // Output
    outdir          = "results"
    store_dir       = null      // Persistent cache dir (opt-in)

    // Assembly
    assembler       = 'flye'        // Assembler: 'flye', 'metamdbg', 'myloasm'
    read_type       = 'auto'        // 'auto', 'nano-hq', 'nano-raw', 'nano-corr'
    min_overlap     = 1000          // Flye --min-overlap
    polish          = null          // Run Flye polisher; null = auto (true for flye, false for others)
    min_barcode_size = 10485760     // Skip barcodes with < 10 MB of reads
    run_remove_human = true         // Remove human reads (minimap2 vs human ref)
    human_ref       = "${projectDir}/../../databases/human_ref/GRCh38_noalt_as.fa.gz"
    dedupe          = true          // BBDuk deduplication before assembly
    dedupe_memory    = '24 GB'
    dedupe_memory_gb = 24
    filtlong_size   = null          // Filtlong -t (e.g. "40000000000"); null = skip

    // Resources (defaults; override with profiles)
    assembly_cpus   = 16
    assembly_memory = '60 GB'
}

// ============================================================================
// Executor
// ============================================================================

def _sysMem = {
    try {
        def kb = new File('/proc/meminfo').readLines()
            .find { it.startsWith('MemTotal:') }?.split()?.getAt(1)?.toLong() ?: 8_000_000L
        return (kb * 1024L) as nextflow.util.MemoryUnit
    } catch (e) { return 8.GB }
}()

executor {
    $local {
        cpus   = Runtime.getRuntime().availableProcessors()
        memory = _sysMem
    }
}

// ============================================================================
// Conda configuration
// ============================================================================

conda {
    enabled    = true
    cacheDir   = "${projectDir}/conda-envs"
    useMamba   = true
    createTimeout = '60 min'
}

// ============================================================================
// Process resource labels
// ============================================================================

process {
    fair = true

    beforeScript = { def d = params.store_dir ?: params.outdir; "mkdir -p '${d}/pipeline_info' && echo '${task.process}\tSTART\t'\$(date -Iseconds) >> '${d}/pipeline_info/pipeline_timing.tsv'" }
    afterScript  = { def d = params.store_dir ?: params.outdir; "echo '${task.process}\tEND\t'\$(date -Iseconds)'\t'\${nxf_main_ret:-0} >> '${d}/pipeline_info/pipeline_timing.tsv'" }

    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = 16.GB
    }
    withLabel: 'process_high' {
        cpus   = { params.assembly_cpus }
        memory = { params.assembly_memory }
    }

    errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    maxRetries    = 1
}

// ============================================================================
// Profiles
// ============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    test {
        params {
            outdir        = "test_results"
            min_overlap   = 1000
            assembly_cpus   = 4
            assembly_memory = '8 GB'
        }
        process {
            withLabel: 'process_high' {
                cpus   = 4
                memory = 8.GB
                time   = 2.h
            }
        }
    }

}

// ============================================================================
// Reports and tracing
// ============================================================================

timeline {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,peak_rss'
}

dag {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// ============================================================================
// Manifest
// ============================================================================

manifest {
    name            = 'dana-nanopore-assembly'
    author          = 'Dana Pipeline'
    description     = 'Nanopore assembly pipeline: preprocessing, co-assembly, mapping, depth calculation'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
