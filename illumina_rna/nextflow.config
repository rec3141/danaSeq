// ============================================================================
// Illumina RNA Pipeline - Nextflow Configuration
// ============================================================================

workDir = "${projectDir}/work"

params {
    // Help
    help            = false

    // Required
    input           = null              // Directory of paired-end *_R1_*.fastq.gz
    references      = null              // Directory of reference <name>.fasta files (+ optional <name>.gff)

    // Output
    outdir          = "results"
    store_dir       = null

    // Preprocessing
    min_readlen     = 50                // RNA-seq reads can be shorter than DNA; 50 is a safer default
    run_remove_human = true
    human_ref       = "${projectDir}/../../databases/human_ref"
    run_fastqc      = true

    // rRNA removal
    run_remove_rrna = true              // SortMeRNA; on by default for metatranscriptomes
    sortmerna_refs  = "${projectDir}/../../databases/sortmerna_refs"

    // Mapping
    min_identity    = 90                // bbmap minid; metatranscriptomic mismatches usually <10%

    // Quantification
    strandedness    = 'unstranded'      // 'unstranded' | 'forward' | 'reverse'
    feature_type    = 'CDS'             // GFF feature column 3 (CDS for Bakta/Prokka)
    attr_type       = 'locus_tag'       // GFF attribute (locus_tag for Bakta/Prokka, ID for generic)

    // Resources
    rna_cpus        = 16
    rna_memory      = '64 GB'

    // SLURM
    slurm_account   = 'def-rec3141'
    conda_path      = null
}

// ============================================================================
// Conda configuration
// ============================================================================

conda {
    enabled    = true
    cacheDir   = "${projectDir}/conda-envs"
    useMamba   = true
    createTimeout = '60 min'
}

// ============================================================================
// Process resource labels
// ============================================================================

process {
    fair = true

    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = 24.GB
        time   = 4.h
    }
    withLabel: 'process_high' {
        cpus   = { [params.rna_cpus as int, Runtime.runtime.availableProcessors()].min() }
        memory = { "${params.rna_memory}" as nextflow.util.MemoryUnit }
        time   = 24.h
    }

    errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    maxRetries    = 1
}

// ============================================================================
// Profiles
// ============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    test {
        params {
            outdir          = "test_results"
            rna_cpus        = 4
            rna_memory      = '8 GB'
        }
        process {
            withLabel: 'process_high' {
                cpus   = 4
                memory = 8.GB
                time   = 2.h
            }
        }
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'default'
        process.clusterOptions = "--account=${params.slurm_account}"
        process.beforeScript = params.conda_path ? "export PATH=${params.conda_path}:\$PATH" : ''

        process {
            withLabel: 'process_low' {
                cpus   = 2
                memory = 4.GB
                time   = 1.h
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = 24.GB
                time   = 4.h
            }
            withLabel: 'process_high' {
                cpus   = { params.rna_cpus as int }
                memory = { "${params.rna_memory}" as nextflow.util.MemoryUnit }
                time   = 24.h
            }
        }
    }
}

// ============================================================================
// Reports and tracing
// ============================================================================

timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";     overwrite = true
           fields  = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,peak_rss' }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html";      overwrite = true }

// ============================================================================
// Manifest
// ============================================================================

manifest {
    name            = 'dana-illumina-rna'
    author          = 'Dana Pipeline'
    description     = 'Illumina RNA-seq pipeline (BBTools QC + SortMeRNA + BBmap to references + featureCounts)'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
