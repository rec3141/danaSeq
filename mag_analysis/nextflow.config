// ============================================================================
// Dana MAG Analysis Pipeline - Nextflow Configuration
// ============================================================================
//
// Technology-agnostic downstream analysis: binning, annotation, taxonomy,
// metabolism, MGE detection, eukaryotic analysis, ecosystem services, viz.
//
// Accepts assembly + depths from any assembler pipeline.
// ============================================================================

// Default parameters (override via CLI: --param_name value)
params {
    // Help
    help            = false

    // Required inputs (from assembly pipeline)
    assembly        = null      // Path to assembly FASTA
    depths          = null      // Path to MetaBAT2-format depth table

    // Optional inputs
    bam_dir         = null      // Directory with *.sorted.bam + .bai (for BAM-based binners)
    tnf             = null      // Tetranucleotide frequency table (for viz)
    assembly_info   = null      // Assembler metadata (for viz)

    // Output
    outdir          = "results"
    store_dir       = null      // Persistent cache dir (opt-in)

    // Binning
    run_semibin     = false
    run_maxbin      = false
    run_lorbin      = false
    run_comebin     = false
    run_vamb        = false
    run_vamb_tax    = false
    run_binette     = false
    run_magscot     = false
    magscot_hmm_dir = null
    metabat_min_cls = 50000
    lorbin_min_length = 80000

    // Annotation
    run_prokka      = false
    run_bakta       = false
    annotator       = 'bakta'
    bakta_db        = null
    bakta_light_db  = null
    bakta_extra      = false

    // Taxonomy
    run_kaiju       = false
    kaiju_db        = null
    run_kraken2     = false
    kraken2_db      = null
    kraken2_confidence = 0.0
    run_sendsketch  = false
    sendsketch_address = null
    run_rrna        = false
    silva_ssu_db    = null
    silva_lsu_db    = null
    rrna_min_identity = 0.80

    // Mobile genetic elements
    run_genomad     = false
    genomad_db      = null
    run_checkv      = false
    checkv_db       = null
    run_integronfinder = false
    run_islandpath  = false
    islandpath_hmm_db = null
    run_macsyfinder = false
    macsyfinder_models = null
    run_defensefinder = false
    defensefinder_models = null

    // Metabolic profiling
    run_metabolism   = false
    kofam_db         = null
    eggnog_db        = null
    dbcan_db         = null
    emapper_batch_size = 50000
    run_antismash    = false
    antismash_db     = null

    // Ecosystem services
    run_ecossdb      = true
    ecossdb_sdg      = true
    ecossdb_role_weights = 'producer:1.0,transformer:0.7,consumer:-0.3,inhibitor:-0.5'

    // Eukaryotic analysis
    run_eukaryotic   = false
    tiara_min_len    = 3000
    whokaryote_min_len = 5000
    run_metaeuk      = false
    metaeuk_db       = null
    metaeuk_mem_limit = '50G'
    metaeuk_min_length = 20
    metaeuk_max_intron = 10000
    run_marferret    = false
    marferret_db     = null

    // Quality assessment
    checkm2_db      = null

    // Phylogenetics
    run_gtdbtk      = false
    gtdbtk_db       = null

    // Viz dashboard
    run_viz         = false
    viz_port        = 5174

    // Resources
    assembly_cpus   = 16
    assembly_memory = '60 GB'
}

// ============================================================================
// Executor
// ============================================================================

def _sysMem = {
    try {
        def kb = new File('/proc/meminfo').readLines()
            .find { it.startsWith('MemTotal:') }?.split()?.getAt(1)?.toLong() ?: 8_000_000L
        return (kb * 1024L) as nextflow.util.MemoryUnit
    } catch (e) { return 8.GB }
}()

executor {
    $local {
        cpus   = Runtime.getRuntime().availableProcessors()
        memory = _sysMem
    }
}

// ============================================================================
// Conda configuration
// ============================================================================

conda {
    enabled    = true
    cacheDir   = "${projectDir}/conda-envs"
    useMamba   = true
    createTimeout = '60 min'
}

// ============================================================================
// Process resource labels
// ============================================================================

process {
    fair = true

    beforeScript = { def d = params.store_dir ?: params.outdir; "mkdir -p '${d}/pipeline_info' && echo '${task.process}\tSTART\t'\$(date -Iseconds) >> '${d}/pipeline_info/pipeline_timing.tsv'" }
    afterScript  = { def d = params.store_dir ?: params.outdir; "echo '${task.process}\tEND\t'\$(date -Iseconds)'\t'\${nxf_main_ret:-0} >> '${d}/pipeline_info/pipeline_timing.tsv'" }

    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = 16.GB
    }
    withLabel: 'process_high' {
        cpus   = { params.assembly_cpus }
        memory = { params.assembly_memory }
    }
    withLabel: 'process_kraken' {
        cpus   = 8
        memory = 24.GB
    }
    withLabel: 'process_gpu' {
        cpus   = 8
        memory = 16.GB
        maxForks = 1
    }

    withName: 'BAKTA_EXTRA' {
        memory = 24.GB
    }
    withName: 'EMAPPER' {
        memory = 48.GB
    }
    withName: 'METAEUK_PREDICT' {
        memory = 32.GB
    }
    withName: 'CALCULATE_GENE_DEPTHS' {
        cpus   = 8
    }
    withName: 'GTDBTK_CLASSIFY' {
        memory = 120.GB
    }

    errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    maxRetries    = 1
}

// ============================================================================
// Profiles
// ============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    test {
        params {
            outdir        = "test_results"
            metabat_min_cls = 10000
            assembly_cpus   = 4
            assembly_memory = '8 GB'
        }
        process {
            withLabel: 'process_high' {
                cpus   = 4
                memory = 8.GB
                time   = 2.h
            }
        }
    }

}

// ============================================================================
// Reports and tracing
// ============================================================================

timeline {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,peak_rss'
}

dag {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// ============================================================================
// Manifest
// ============================================================================

manifest {
    name            = 'dana-mag-analysis'
    author          = 'Dana Pipeline'
    description     = 'Technology-agnostic MAG analysis: binning, annotation, taxonomy, metabolism, MGEs, eukaryotes, viz'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
